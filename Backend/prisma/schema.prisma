// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/config/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  WORKER
  ENGINEER
  ACCOUNTANT
  ADMIN
  SALES_REP
}

enum InventoryType {
  IN
  OUT
}

enum ReferenceType {
  PRODUCTION
  PURCHASE
  SALE
}

enum ProductType {
  CAPS
  PREFORM
}

enum InventoryAuditFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum MachineStatus {
  OPERATIONAL
  UNDER_MAINTENANCE
  BROKEN
  OFFLINE
  DECOMMISSIONED
}

enum DowntimeReason {
  BELT_FAILURE
  MOTOR_ISSUE
  HYDRAULIC_FAILURE
  SEAL_LEAK
  ELECTRICAL
  SENSOR_MALFUNCTION
  SCHEDULED_MAINTENANCE
  OTHER
}

enum QualityStatus {
  PASS
  FAIL
  REWORK_REQUIRED
  PENDING_REVIEW
}

enum NotificationType {
  CHAT_MESSAGE
  PRODUCTION_ALERT
  MAINTENANCE_URGENT
  QUALITY_ISSUE
  SYSTEM_MESSAGE
  PAYROLL_READY
  INVENTORY_LOW
  ENGINEER_INVENTORY
  RAW_MATERIAL_ALERT
  REGISTRATION_REQUEST
}

enum RegistrationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EngineerInventoryStatus {
  DRAFT
  SUBMITTED
  REVIEWED
}

enum FileType {
  PROFILE_IMAGE
  ID_IMAGE
  INVOICE
  MACHINE_READING
  MAINTENANCE_REPORT
  QUALITY_REPORT
}

//////////////////////
// CORE TABLES
//////////////////////

model User {
  id           Int      @id @default(autoincrement())
  nationalId   String   @unique
  fullName     String
  username     String   @unique
  phone        String?
  email        String?  @unique
  password     String
  idImage      String?
  profileImage     String?
  role             UserRole
  isActive         Boolean  @default(true)
  monthlySalary    Float?   // per-user salary override; takes priority over role-based SalaryConfig

  // Extended profile
  bio              String?
  jobTitle         String?
  department       String?
  dateOfBirth      DateTime?
  address          String?
  linkedIn         String?
  skills           String?   // JSON array stored as string
  profileCompleted Boolean   @default(false)

  shiftId Int?
  shift   Shift? @relation(fields: [shiftId], references: [id])

  attendances   Attendance[]
  machineReads  MachineReading[]
  productions   ProductionRecord[]
  maintenances  Maintenance[]
  qualityChecks QualityCheck[]
  payrolls      Payroll[]
  dailyPayrolls        DailyPayroll[] @relation("UserDailyPayrolls")
  confirmedDailyPayrolls DailyPayroll[] @relation("ConfirmedPayrolls")
  salaryConfigUpdates  SalaryConfig[] @relation("SalaryConfigUpdater")
  notifications Notification[]
  pushTokens    PushToken[]

  electricityRecorded      ElectricityReading[]   @relation("ElectricityRecorder")
  electricityEngineered    ElectricityReading[]   @relation("ElectricityEngineer")
  electricityKwhPricesSet  ElectricityKwhPrice[]  @relation("KwhPriceSetter")
  inventoryTransactions InventoryTransaction[]
  purchases             Purchase[]
  sales                 Sale[]

  // Engineer features
  machineHealthRecords     MachineHealthRecord[] @relation("MachineHealthRecorder")
  assignedMaintenance      MaintenanceSchedule[] @relation("AssignedMaintenance")
  maintenanceSchedules     MaintenanceSchedule[] @relation("MaintenanceScheduleCreator")

  // Accountant features - Phase 1
  expensesCreated     Expense[] @relation("ExpenseCreator")
  expensesApproved    Expense[] @relation("ExpenseApprover")
  invoicesCreated     Invoice[] @relation("InvoiceCreator")
  financialSettings   FinancialSetting[] @relation("FinancialSettingUpdater")

  // Accountant features - Phase 2
  financialReports       FinancialReport[] @relation("FinancialReportGenerator")
  budgetPlans            BudgetPlan[] @relation("BudgetPlanCreator")
  taxFilings             TaxFiling[] @relation("TaxFilingFiler")
  bankReconciliations    BankReconciliation[] @relation("BankReconciliationReconciler")
  approvalWorkflows      ApprovalWorkflow[] @relation("ApprovalWorkflowCreator")

  // 🔥 CHAT RELATIONS
  createdGroups    ChatGroup[]    @relation("GroupCreator")
  groupMemberships GroupMember[]
  sentMessages     GroupMessage[]

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  productionSettings ProductionSetting[]
  systemSettings     SystemSetting[]
  auditLogs          AuditLog[]
  fileAttachments    FileAttachment[]
  machineStatusChanges Machine[] @relation("StatusChangedBy")

  engineerInventories  EngineerInventory[]
  inventoryReviews     EngineerInventory[]     @relation("InventoryReviewer")
  inventoryItemPricing EngineerInventoryItem[] @relation("ItemPricer")

  performanceRecords         EmployeePerformance[] @relation("PerformanceUser")
  calculatedPerformances     EmployeePerformance[] @relation("PerformanceCalculator")
  maintenanceCostsCreated    MaintenanceCost[]     @relation("MaintenanceCostCreator")
  userDocuments              UserDocument[]
  reviewedRegistrationRequests RegistrationRequest[] @relation("RegistrationReviewer")
  deductionRulesUpdated        DeductionRule[]        @relation("DeductionRuleUpdater")

  sparePartRequestsAsEngineer  SparePartRequest[]    @relation("SparePartRequestEngineer")
  sparePartRequestsAsPricer    SparePartRequest[]    @relation("SparePartRequestPricer")
  techDocumentsUploaded        TechDocument[]        @relation("TechDocUploader")
  customerReturnsRecorded      CustomerReturn[]      @relation("CustomerReturnRecorder")

  // Sales rep features
  quotations         Quotation[]      @relation("QuotationCreator")
  assignedCustomers  Customer[]       @relation("AssignedSalesRep")
  customerVisits     CustomerVisit[]  @relation("VisitLogger")
  salesTargets       SalesTarget[]    @relation("SalesTargetRep")

  // Indices for common queries
  @@index([email])
  @@index([username])
}

model UserDocument {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName     String
  filePath     String
  fileSize     Int
  mimeType     String
  documentType String   // CV, CERTIFICATE, OTHER
  title        String
  createdAt    DateTime @default(now())
}

model Shift {
  id        Int      @id @default(autoincrement())
  name      String
  startTime DateTime
  endTime   DateTime

  users            User[]
  attendances      Attendance[]
  productions      ProductionRecord[]
  maintenances     Maintenance[]
  qualityChecks    QualityCheck[]
  machineReads     MachineReading[]
  electricityReadings ElectricityReading[]
}

model Attendance {
  id              Int       @id @default(autoincrement())
  userId          Int
  shiftId         Int?
  checkIn         DateTime
  checkOut        DateTime?
  lateMinutes     Int       @default(0)
  overtimeMinutes Int       @default(0)
  leaveType       String?
  notes           String?

  user         User         @relation(fields: [userId], references: [id])
  shift        Shift?       @relation(fields: [shiftId], references: [id])
  dailyPayroll DailyPayroll?

  createdAt DateTime @default(now())
}

model AttendanceSetting {
  id                   Int      @id @default(autoincrement())
  lateGraceMinutes     Int      @default(30)
  overtimeGraceMinutes Int      @default(30)
  updatedAt            DateTime @updatedAt
}

//////////////////////
// MACHINES
//////////////////////

model Machine {
  id      Int    @id @default(autoincrement())
  name    String
  type    String
  status  MachineStatus @default(OPERATIONAL)

  statusChangedBy  Int?
  statusChangedAt  DateTime?

  productions   ProductionRecord[]
  maintenances  Maintenance[]
  qualityChecks QualityCheck[]
  readings      MachineReading[]
  notifications Notification[]
  machineHealthRecords  MachineHealthRecord[]
  maintenanceSchedules  MaintenanceSchedule[]
  spareParts            SparePart[]
  sparePartRequests     SparePartRequest[]

  statusChangedByUser User? @relation("StatusChangedBy", fields: [statusChangedBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model MachineReading {
  id           Int     @id @default(autoincrement())
  machineId    Int
  userId       Int
  shiftId      Int
  startCounter Int
  endCounter   Int
  imagePath    String?

  machine Machine @relation(fields: [machineId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  shift   Shift   @relation(fields: [shiftId], references: [id])

  fileAttachments FileAttachment[]

  recordedAt DateTime @default(now())
}

model ElectricityKwhPrice {
  id            Int      @id @default(autoincrement())
  price         Float
  effectiveFrom DateTime @default(now())
  notes         String?
  setById       Int
  setBy         User     @relation("KwhPriceSetter", fields: [setById], references: [id])

  readings ElectricityReading[]

  createdAt DateTime @default(now())
}

model ElectricityReading {
  id                    Int      @id @default(autoincrement())
  date                  DateTime
  shiftId               Int
  startReading          Float
  endReading            Float
  isMeterReset          Boolean  @default(false)
  maxMeterValue         Float?
  consumption           Float
  kwhPriceId            Int
  kwhPriceSnap          Float
  shiftCost             Float
  notes                 String?
  imagePath             String?
  recordedById          Int
  responsibleEngineerId Int?

  shift               Shift              @relation(fields: [shiftId], references: [id])
  recordedBy          User               @relation("ElectricityRecorder", fields: [recordedById], references: [id])
  responsibleEngineer User?              @relation("ElectricityEngineer", fields: [responsibleEngineerId], references: [id])
  kwhPrice            ElectricityKwhPrice @relation(fields: [kwhPriceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([shiftId])
}

//////////////////////
// PRODUCTION
//////////////////////

model ProductionRecord {
  id        Int    @id @default(autoincrement())
  machineId Int?
  userId    Int
  shiftId   Int
  hourSlot  String

  cartonsCount    Int @default(0)
  piecesPerCarton Int @default(0)
  totalPieces     Int @default(0)
  workingCavities Int?

  rawHdpeUsed   Float?
  rawLdpeUsed   Float?
  rawPetUsed    Float?
  adhesiveUsed  Float?
  emptyBagsUsed Float?
  colorUsed     Float?

  damagedPieces   Int     @default(0)
  netGoodPieces   Int     @default(0)
  capColor        String?
  preformType     String?

  downtimeReason  String?
  downtimeMinutes Int?

  boxesData    String?
  documentPath String?

  notes String?

  date DateTime @default(now())

  machine Machine? @relation(fields: [machineId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  shift   Shift    @relation(fields: [shiftId], references: [id])

  notifications Notification[]

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([date])
}

//////////////////////
// MAINTENANCE & QUALITY
//////////////////////

model Maintenance {
  id              Int      @id @default(autoincrement())
  machineId       Int
  engineerId      Int
  shiftId         Int
  partsUsed       String
  downtimeMinutes Int?
  downtimeReason  DowntimeReason @default(OTHER)
  reportText      String?
  imagePath       String?

  machine  Machine @relation(fields: [machineId], references: [id])
  engineer User    @relation(fields: [engineerId], references: [id])
  shift    Shift   @relation(fields: [shiftId], references: [id])

  fileAttachments FileAttachment[]
  costs MaintenanceCost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QualityCheck {
  id             Int @id @default(autoincrement())
  machineId      Int
  engineerId     Int
  shiftId        Int?
  issueType      String // "DIMENSIONAL", "SURFACE_DEFECT", "MATERIAL_FAULT", etc.
  severity       String // "LOW", "MEDIUM", "HIGH", "CRITICAL"
  description    String?
  resolvedAt     DateTime?

  machine  Machine @relation(fields: [machineId], references: [id])
  engineer User    @relation(fields: [engineerId], references: [id])
  shift    Shift?  @relation(fields: [shiftId], references: [id])

  fileAttachments FileAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////
// INVENTORY
//////////////////////

model RawMaterial {
  id              Int    @id @default(autoincrement())
  name            String
  currentQuantity Float
  unit            String

  transactions  InventoryTransaction[]
  purchaseItems PurchaseItem[]
  minQuantity   Float   @default(0)
  alerts        RawMaterialAlert[]
}

model InventoryTransaction {
  id            Int           @id @default(autoincrement())
  materialId    Int
  type          InventoryType
  quantity      Float
  referenceType ReferenceType
  referenceId   Int?
  createdById   Int?

  material  RawMaterial @relation(fields: [materialId], references: [id])
  createdBy User?       @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([materialId])
}

//////////////////////
// PURCHASES
//////////////////////

model Supplier {
  id      Int     @id @default(autoincrement())
  name    String
  phone   String?
  email   String?
  address String?

  purchases Purchase[]
  payables  SupplierPayable[]

  contactPerson String?
  website       String?
  category      String? // "RAW_MATERIALS", "SPARE_PARTS", "EQUIPMENT", "SERVICES", "OTHER"
  leadTimeDays  Int?
  rating        Float?  // 1.0 - 5.0
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model Purchase {
  id           Int      @id @default(autoincrement())
  supplierId   Int
  receivedById Int
  totalAmount  Float
  invoiceImage String
  date         DateTime

  supplier   Supplier       @relation(fields: [supplierId], references: [id])
  receivedBy User           @relation(fields: [receivedById], references: [id])
  items      PurchaseItem[]
  fileAttachments FileAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseItem {
  id           Int   @id @default(autoincrement())
  purchaseId   Int
  materialId   Int
  quantity     Float
  pricePerUnit Float

  purchase Purchase    @relation(fields: [purchaseId], references: [id])
  material RawMaterial @relation(fields: [materialId], references: [id])
}

//////////////////////
// SALES
//////////////////////

model Customer {
  id                 Int     @id @default(autoincrement())
  name               String
  phone              String?
  email              String?
  address            String?
  assignedSalesRepId Int?

  assignedSalesRep User?                @relation("AssignedSalesRep", fields: [assignedSalesRepId], references: [id])
  sales            Sale[]
  invoices         Invoice[]
  receivables      CustomerReceivable[]
  returns          CustomerReturn[]
  quotations       Quotation[]
  visits           CustomerVisit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model CustomerReturn {
  id           Int      @id @default(autoincrement())
  customerId   Int?
  customerName String
  productType  String   // "CAPS" | "PREFORM" | "OTHER"
  quantity     Float
  returnDate   DateTime
  notes        String?
  invoicePdf   String?
  recordedById Int?

  customer   Customer? @relation(fields: [customerId], references: [id])
  recordedBy User?     @relation("CustomerReturnRecorder", fields: [recordedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sale {
  id           Int      @id @default(autoincrement())
  customerId   Int
  soldById     Int
  totalAmount  Float
  invoiceImage String
  date         DateTime

  customer   Customer         @relation(fields: [customerId], references: [id])
  soldBy     User             @relation(fields: [soldById], references: [id])
  items      SaleItem[]
  aiAnalysis InvoiceAnalysis?
  fileAttachments FileAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

model SaleItem {
  id           Int    @id @default(autoincrement())
  saleId       Int
  machineType  String
  size         String
  quantity     Float
  pricePerUnit Float

  sale Sale @relation(fields: [saleId], references: [id])
}

//////////////////////
// AI INVOICE ANALYSIS
//////////////////////

model InvoiceAnalysis {
  id                    Int       @id @default(autoincrement())
  saleId                Int       @unique
  extractedCustomerName String?
  extractedProduct      String?
  extractedQuantity     Float?
  extractedDate         DateTime?
  confidenceScore       Float?

  sale Sale @relation(fields: [saleId], references: [id])

  processedAt DateTime @default(now())
}

//////////////////////
// PAYROLL
//////////////////////

model SalaryConfig {
  id            Int      @id @default(autoincrement())
  role          UserRole @unique
  monthlySalary Float
  updatedById   Int?
  updatedBy     User?    @relation("SalaryConfigUpdater", fields: [updatedById], references: [id])
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())
}

model DailyPayroll {
  id               Int       @id @default(autoincrement())
  userId           Int
  attendanceId     Int?      @unique
  date             DateTime
  hoursWorked      Float
  dailyRate        Float
  totalDailyPay    Float
  deductionAmount  Float     @default(0)
  deductionNotes   String?
  isConfirmed      Boolean   @default(false)
  confirmedById    Int?
  confirmedAt      DateTime?
  notificationSent Boolean   @default(false)

  user        User        @relation("UserDailyPayrolls", fields: [userId], references: [id])
  confirmedBy User?       @relation("ConfirmedPayrolls", fields: [confirmedById], references: [id])
  attendance  Attendance? @relation(fields: [attendanceId], references: [id])

  createdAt DateTime @default(now())
}

model Payroll {
  id             Int    @id @default(autoincrement())
  userId         Int
  month          String
  totalHours     Float
  overtimeHours  Float
  baseSalary     Float
  overtimeSalary Float
  totalSalary    Float

  user User @relation(fields: [userId], references: [id])

  calculatedAt DateTime @default(now())
}

// type values: "LATE_ARRIVAL" | "EARLY_CHECKOUT" | "UNEXCUSED_ABSENCE" | "SICK_LEAVE"
// deductionValue: NIS/hr for LATE_ARRIVAL; pay-rate % (0-100) for SICK_LEAVE; ignored for others
model DeductionRule {
  id               Int      @id @default(autoincrement())
  type             String   @unique
  isActive         Boolean  @default(false)
  thresholdMinutes Int      @default(15)
  deductionValue   Float    @default(0)
  updatedById      Int?
  updatedBy        User?    @relation("DeductionRuleUpdater", fields: [updatedById], references: [id])
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}

//////////////////////
// ENGINEER FEATURES
//////////////////////

model MachineHealthRecord {
  id                   Int     @id @default(autoincrement())
  machineId            Int
  recordedById         Int

  operationalStatus    String  // "OPERATIONAL", "MAINTENANCE", "BROKEN", "OFFLINE"
  downtimePercentage   Float
  maintenanceHours     Int
  efficiencyRating     Int     // 0-100
  notes                String?

  machine              Machine @relation(fields: [machineId], references: [id])
  recordedBy           User    @relation("MachineHealthRecorder", fields: [recordedById], references: [id])

  recordedAt           DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model MaintenanceSchedule {
  id                   Int     @id @default(autoincrement())
  machineId            Int
  assignedEngineerId   Int?
  createdById          Int

  scheduleType         String  // "PREVENTIVE", "CORRECTIVE", "PREDICTIVE"
  frequency            String  // "DAILY", "WEEKLY", "MONTHLY", "QUARTERLY", "YEARLY"
  lastScheduledDate    DateTime?
  nextScheduledDate    DateTime
  status               String  @default("PENDING") // "PENDING", "IN_PROGRESS", "COMPLETED", "OVERDUE"
  description          String?

  machine              Machine @relation(fields: [machineId], references: [id])
  assignedEngineer     User?   @relation("AssignedMaintenance", fields: [assignedEngineerId], references: [id])
  createdBy            User    @relation("MaintenanceScheduleCreator", fields: [createdById], references: [id])

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model SparePart {
  id                   Int     @id @default(autoincrement())
  machineId            Int

  name                 String
  quantity             Int
  minQuantity          Int
  unitPrice            Float
  supplier             String?
  lastRestockedDate    DateTime?
  expiryDate           DateTime?
  notes                String?

  machine              Machine @relation(fields: [machineId], references: [id])

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model SparePartRequest {
  id          Int       @id @default(autoincrement())
  engineerId  Int
  machineId   Int
  partName    String
  quantity    Int
  imagePath   String?
  status          String    @default("PENDING") // PENDING | RECEIVED
  unitPrice       Float?
  pricedById      Int?
  pricedAt        DateTime?
  receivedAt      DateTime?
  notes           String?
  supplierName    String?
  supplierCountry String?

  engineer    User     @relation("SparePartRequestEngineer", fields: [engineerId], references: [id])
  machine     Machine  @relation(fields: [machineId], references: [id])
  pricedBy    User?    @relation("SparePartRequestPricer", fields: [pricedById], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TechDocument {
  id            Int      @id @default(autoincrement())
  title         String
  category      String   // Manual | Maintenance | Safety | Reference | Support | Other
  description   String?
  fileName      String?
  filePath      String?
  fileSize      Int?
  mimeType      String?
  images        String[] @default([])
  downloadCount Int      @default(0)
  uploadedById  Int

  uploadedBy    User     @relation("TechDocUploader", fields: [uploadedById], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

//////////////////////
// ACCOUNTANT FEATURES
//////////////////////

model Expense {
  id                   Int     @id @default(autoincrement())
  submittedById        Int
  approvedById         Int?

  category             String  // "MATERIALS", "UTILITIES", "MAINTENANCE", "TRAVEL", "OTHER"
  amount               Float
  description          String?
  receiptPath          String?
  paymentStatus        String  @default("PENDING") // "PENDING", "APPROVED", "REJECTED", "PAID"

  submittedAt          DateTime @default(now())
  approvedAt           DateTime?

  submittedBy          User    @relation("ExpenseCreator", fields: [submittedById], references: [id])
  approvedBy           User?   @relation("ExpenseApprover", fields: [approvedById], references: [id])

  updatedAt            DateTime @updatedAt
}

model Invoice {
  id                   Int     @id @default(autoincrement())
  customerId           Int
  createdById          Int

  invoiceNumber        String  @unique
  totalAmount          Float
  dueDate              DateTime
  paymentStatus        String  @default("PENDING") // "PENDING", "PAID", "OVERDUE", "CANCELLED"
  invoicePath          String?

  paymentRecordedAt    DateTime?

  // Extended fields (added for AI extraction + full invoice detail)
  issueDate            DateTime?
  currency             String?   @default("USD")
  subtotal             Float?
  taxAmount            Float?
  notes                String?
  lineItems            String?   // JSON: [{description,quantity,unitPrice,total}]
  aiExtracted          Boolean   @default(false)

  // Vendor info
  vendorName           String?
  vendorPhone          String?
  vendorEmail          String?
  vendorAddress        String?

  // Customer extended info
  customerPhone        String?
  customerEmail        String?
  customerAddress      String?

  // Shipment / Receipt
  invoiceType          String    @default("REGULAR") // REGULAR | SHIPMENT | RECEIPT
  driverName           String?
  departureTime        DateTime?
  confirmedAt          DateTime?
  confirmedByName      String?

  customer             Customer @relation(fields: [customerId], references: [id])
  createdBy            User    @relation("InvoiceCreator", fields: [createdById], references: [id])

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model FinancialSetting {
  id                   Int     @id @default(autoincrement())
  updatedById          Int?

  revenueTarget        Float   @default(0)
  expenseLimit         Float   @default(0)
  profitMarginTarget   Float   @default(0) // 0-100

  updatedBy            User?   @relation("FinancialSettingUpdater", fields: [updatedById], references: [id])

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ── Phase 2 Financial Features ──

model FinancialReport {
  id              Int     @id @default(autoincrement())
  title           String
  reportType      String  // P&L, BalanceSheet, CashFlow, etc
  period          String  // "March 2026", "Q1 2026", etc
  generatedById   Int
  pdfPath         String?

  generatedBy     User    @relation("FinancialReportGenerator", fields: [generatedById], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SupplierPayable {
  id              Int     @id @default(autoincrement())
  supplierId      Int
  amount          Float
  dueDate         DateTime
  paymentStatus   String  @default("PENDING") // PENDING, PAID, OVERDUE
  notes           String?

  supplier        Supplier @relation(fields: [supplierId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CustomerReceivable {
  id              Int     @id @default(autoincrement())
  customerId      Int
  amount          Float
  dueDate         DateTime
  status          String  @default("PENDING") // PENDING, PAID, OVERDUE
  notes           String?

  customer        Customer @relation(fields: [customerId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BudgetPlan {
  id              Int     @id @default(autoincrement())
  month           String  // "2026-04"
  category        String
  allocated       Float
  spent           Float   @default(0)
  createdById     Int

  createdBy       User    @relation("BudgetPlanCreator", fields: [createdById], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TaxFiling {
  id              Int     @id @default(autoincrement())
  filingType      String  // VAT, Income, Payroll, etc
  dueDate         DateTime
  amount          Float
  status          String  @default("PENDING") // PENDING, FILED, PAID
  filedById       Int?

  filedBy         User?   @relation("TaxFilingFiler", fields: [filedById], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BankReconciliation {
  id              Int     @id @default(autoincrement())
  accountName     String
  bankBalance     Float
  bookBalance     Float
  reconciled      Boolean @default(false)
  reconciledById  Int?
  notes           String?

  reconciledBy    User?   @relation("BankReconciliationReconciler", fields: [reconciledById], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CostAnalysis {
  id              Int     @id @default(autoincrement())
  category        String
  cost            Float
  percentage      Float   // % of total
  period          String  // "2026-04"
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ApprovalWorkflow {
  id              Int     @id @default(autoincrement())
  workflowName    String
  status          String  @default("ACTIVE") // ACTIVE, DRAFT, INACTIVE
  itemsCount      Int     @default(0)
  approverCount   Int     @default(0)
  createdById     Int

  createdBy       User    @relation("ApprovalWorkflowCreator", fields: [createdById], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

//////////////////////
// NOTIFICATIONS
//////////////////////

model Notification {
  id           Int                @id @default(autoincrement())
  userId       Int
  title        String
  message      String
  type         NotificationType
  isRead       Boolean            @default(false)
  readAt       DateTime?

  chatGroupId  Int?
  machineId    Int?
  productionId Int?

  user             User              @relation(fields: [userId], references: [id])
  chatGroup        ChatGroup?        @relation(fields: [chatGroupId], references: [id])
  machine          Machine?          @relation(fields: [machineId], references: [id])
  productionRecord ProductionRecord? @relation(fields: [productionId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, isRead])
}

model PushToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  platform  String   // "android" | "ios"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

//////////////////////
// SETTINGS
//////////////////////

model ProductionSetting {
  id              Int         @id @default(autoincrement())
  productType     ProductType @unique
  piecesPerCarton Int
  updatedById     Int?

  updatedBy User? @relation(fields: [updatedById], references: [id])

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model SystemSetting {
  id                          Int                     @id @default(autoincrement())
  qualityCheckIntervalMinutes Int
  qualityCheckReminderMinutes Int
  inventoryAuditFrequency     InventoryAuditFrequency
  shiftEndReminderMinutes     Int
  weeklyReportDayOfWeek       Int
  weeklyReportTime            String
  monthlyReportDayOfMonth     Int
  monthlyReportTime           String
  updatedById                 Int?

  updatedBy User? @relation(fields: [updatedById], references: [id])

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

//////////////////////
// GROUP CHAT SYSTEM
//////////////////////

enum GroupCategory {
  DEPARTMENT
  TEAM
  PROJECT
  GENERAL
}

model ChatGroup {
  id          Int            @id @default(autoincrement())
  name        String
  description String?
  createdById Int
  category    GroupCategory  @default(GENERAL)

  createdBy User           @relation("GroupCreator", fields: [createdById], references: [id])
  members   GroupMember[]
  messages  GroupMessage[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
}

model GroupMember {
  id      Int       @id @default(autoincrement())
  groupId Int
  userId  Int
  role    GroupRole @default(MEMBER)
  lastReadAt DateTime @default(now())

  group ChatGroup @relation(fields: [groupId], references: [id])
  user  User      @relation(fields: [userId], references: [id])

  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
}

enum GroupRole {
  ADMIN
  MEMBER
}

model GroupMessage {
  id       Int @id @default(autoincrement())
  groupId  Int
  senderId Int

  content String

  group  ChatGroup @relation(fields: [groupId], references: [id])
  sender User      @relation(fields: [senderId], references: [id])

  createdAt DateTime @default(now())
}

//////////////////////
// AUDIT & FILE MANAGEMENT
//////////////////////

model AuditLog {
  id        Int     @id @default(autoincrement())
  userId    Int?
  action    String  // "USER_CREATED", "PAYROLL_CALCULATED", "INVENTORY_ADJUSTED", etc.
  entityType String // "User", "Payroll", "InventoryTransaction", etc.
  entityId  Int?
  changes   String? // JSON object with before/after values

  user User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

//////////////////////
// ENGINEER INVENTORY
//////////////////////

model EngineerInventory {
  id           Int                     @id @default(autoincrement())
  engineerId   Int
  month        Int
  year         Int
  status       EngineerInventoryStatus @default(DRAFT)
  notes        String?

  engineer     User                    @relation(fields: [engineerId], references: [id])
  items        EngineerInventoryItem[]

  submittedAt  DateTime?
  reviewedAt   DateTime?
  reviewedById Int?
  reviewedBy   User?                   @relation("InventoryReviewer", fields: [reviewedById], references: [id])

  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@unique([engineerId, month, year])
}

model EngineerInventoryItem {
  id          Int               @id @default(autoincrement())
  inventoryId Int
  partName    String
  imagePath   String?
  quantity    Int
  unitPrice   Float?
  pricedById  Int?
  pricedAt    DateTime?

  inventory   EngineerInventory @relation(fields: [inventoryId], references: [id])
  pricedBy    User?             @relation("ItemPricer", fields: [pricedById], references: [id])

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model FileAttachment {
  id                Int      @id @default(autoincrement())
  fileName          String
  filePath          String
  fileSize          Int
  mimeType          String
  fileType          FileType

  userId            Int?
  purchaseId        Int?
  saleId            Int?
  machineReadingId  Int?
  maintenanceId     Int?
  qualityCheckId    Int?

  user             User?           @relation(fields: [userId], references: [id])
  purchase         Purchase?       @relation(fields: [purchaseId], references: [id])
  sale             Sale?           @relation(fields: [saleId], references: [id])
  machineReading   MachineReading? @relation(fields: [machineReadingId], references: [id])
  maintenance      Maintenance?    @relation(fields: [maintenanceId], references: [id])
  qualityCheck     QualityCheck?   @relation(fields: [qualityCheckId], references: [id])

  uploadedAt DateTime @default(now())
  deletedAt  DateTime?
}

//////////////////////
// NEW FEATURES
//////////////////////

model RawMaterialAlert {
  id           Int      @id @default(autoincrement())
  materialId   Int
  material     RawMaterial @relation(fields: [materialId], references: [id])
  minQuantity  Float    @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model EmployeePerformance {
  id              Int      @id @default(autoincrement())
  userId          Int
  periodType      String   // "DAILY" | "WEEKLY"
  periodDate      DateTime // start of the period
  productionScore Float    @default(0) // 0-100
  qualityScore    Float    @default(0) // 0-100
  attendanceScore Float    @default(0) // 0-100
  kaizenScore     Float    @default(0) // 0-100
  totalScore      Float    @default(0) // average of above
  notes           String?
  calculatedById  Int?

  user         User  @relation("PerformanceUser", fields: [userId], references: [id])
  calculatedBy User? @relation("PerformanceCalculator", fields: [calculatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MaintenanceCost {
  id             Int      @id @default(autoincrement())
  maintenanceId  Int
  laborHours     Float    @default(0)
  laborCostPerHour Float  @default(0)
  sparesTotal    Float    @default(0)
  laborTotal     Float    @default(0)
  totalCost      Float    @default(0)
  notes          String?
  createdById    Int?

  maintenance Maintenance @relation(fields: [maintenanceId], references: [id])
  createdBy   User?       @relation("MaintenanceCostCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RegistrationRequest {
  id           Int                        @id @default(autoincrement())
  fullName     String
  email        String
  phone        String?
  message      String?
  status       RegistrationRequestStatus  @default(PENDING)
  role         UserRole?
  reviewNote   String?
  reviewedAt   DateTime?
  reviewedById Int?
  reviewedBy   User?                      @relation("RegistrationReviewer", fields: [reviewedById], references: [id])
  createdAt    DateTime                   @default(now())
}

//////////////////////
// SALES REP
//////////////////////

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Quotation {
  id            Int             @id @default(autoincrement())
  customerId    Int
  createdById   Int
  status        QuotationStatus @default(DRAFT)
  notes         String?
  rejectionNote String?
  validUntil    DateTime?
  totalAmount   Float           @default(0)

  customer   Customer        @relation(fields: [customerId], references: [id])
  createdBy  User            @relation("QuotationCreator", fields: [createdById], references: [id])
  items      QuotationItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuotationItem {
  id           Int    @id @default(autoincrement())
  quotationId  Int
  productType  String
  size         String
  quantity     Float
  pricePerUnit Float

  quotation Quotation @relation(fields: [quotationId], references: [id])
}

model CustomerVisit {
  id          Int      @id @default(autoincrement())
  customerId  Int
  loggedById  Int
  visitDate   DateTime
  outcome     String?
  notes       String?
  nextVisitAt DateTime?

  customer Customer @relation(fields: [customerId], references: [id])
  loggedBy User     @relation("VisitLogger", fields: [loggedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visitDate])
}

model SalesTarget {
  id         Int   @id @default(autoincrement())
  repId      Int
  month      Int
  year       Int
  targetAmount Float
  achievedAmount Float @default(0)
  notes      String?

  rep User @relation("SalesTargetRep", fields: [repId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([repId, month, year])
}
